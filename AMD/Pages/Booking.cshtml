@page
@model AMD.Pages.BookingModel
@{
    ViewData["Title"] = "Book Your Event | AMD Audio & Lighting";
}

@section Styles {
    <style>
        /* [KEEP ALL YOUR EXISTING STYLES HERE - same as before] */
        .booking-header {
            background: linear-gradient(rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.92)), url('/images/booking-bg.jpg') center/cover no-repeat;
            color: white;
            padding: 120px 0 80px;
            position: relative;
            margin-bottom: 60px;
        }
        .booking-header::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60px;
            background: linear-gradient(to bottom, transparent, #f8fafc);
        }
        .booking-title { font-size: 2.8rem; font-weight: 800; margin-bottom: 15px; color: white; }
        .booking-subtitle { font-size: 1.1rem; color: #cbd5e1; max-width: 600px; line-height: 1.6; margin-bottom: 25px; }
        .contact-badges { display: flex; flex-wrap: wrap; gap: 15px; margin-top: 30px; }
        .contact-badge { background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 50px; padding: 10px 20px; display: inline-flex; align-items: center; gap: 8px; color: white; font-size: 0.9rem; text-decoration: none; transition: all 0.2s ease; }
        .contact-badge:hover { background: rgba(255, 255, 255, 0.2); transform: translateY(-2px); }
        .booking-section { padding: 40px 0 80px; }
        .booking-container { max-width: 900px; margin: 0 auto; }
        .form-card { background: white; border-radius: 16px; box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08); overflow: hidden; border: 1px solid #e2e8f0; }
        .form-header { background: linear-gradient(135deg, #2563eb, #7c3aed); color: white; padding: 30px; }
        .form-header h2 { font-size: 1.5rem; font-weight: 600; margin: 0; }
        .form-header p { opacity: 0.9; font-size: 0.95rem; margin-top: 5px; }
        .form-body { padding: 40px; }
        .form-step { margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid #e2e8f0; }
        .step-title { font-size: 1.2rem; color: #0f172a; margin-bottom: 20px; font-weight: 600; display: flex; align-items: center; gap: 10px; }
        .step-number { width: 30px; height: 30px; background: linear-gradient(135deg, #2563eb, #7c3aed); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 0.9rem; font-weight: 600; }
        .form-group { margin-bottom: 20px; }
        .form-label { display: block; margin-bottom: 8px; color: #475569; font-weight: 500; font-size: 0.95rem; }
        .form-control-custom { width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.95rem; color: #0f172a; transition: all 0.2s ease; background: white; }
        .form-control-custom:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
        .form-control-custom::placeholder { color: #94a3b8; }
        .form-select { width: 100%; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.95rem; color: #0f172a; background: white; cursor: pointer; }
        .form-select:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
        textarea.form-control-custom { min-height: 120px; resize: vertical; }
        .event-type-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 20px; }
        .event-type-card { border: 2px solid #e2e8f0; border-radius: 10px; padding: 20px; cursor: pointer; transition: all 0.2s ease; text-align: center; background: white; }
        .event-type-card:hover { border-color: #2563eb; transform: translateY(-2px); }
        .event-type-card.selected { border-color: #2563eb; background: #f0f7ff; }
        .event-type-icon { font-size: 1.8rem; color: #2563eb; margin-bottom: 10px; }
        .event-type-name { font-weight: 600; color: #0f172a; margin-bottom: 5px; }
        .event-type-desc { font-size: 0.85rem; color: #64748b; }
        .equipment-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px; }
        .equipment-item { border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; display: flex; align-items: center; gap: 15px; background: white; transition: all 0.2s ease; cursor: pointer; }
        .equipment-item:hover { border-color: #2563eb; background: #f8fafc; }
        .equipment-icon { width: 50px; height: 50px; background: linear-gradient(135deg, #f1f5f9, #e2e8f0); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #2563eb; }
        .equipment-info { flex: 1; }
        .equipment-info h4 { margin: 0 0 5px 0; font-size: 1rem; color: #0f172a; font-weight: 600; }
        .equipment-desc { font-size: 0.85rem; color: #64748b; margin: 0; }
        .equipment-checkbox { width: 22px; height: 22px; border: 2px solid #cbd5e1; border-radius: 4px; cursor: pointer; position: relative; flex-shrink: 0; }
        .equipment-checkbox.checked { background: #2563eb; border-color: #2563eb; }
        .equipment-checkbox.checked::after { content: '✓'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: white; font-size: 0.8rem; font-weight: bold; }
        .equipment-category { margin-bottom: 25px; }
        .category-title { font-size: 1.1rem; color: #0f172a; margin-bottom: 15px; font-weight: 600; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0; }
        .submit-btn { background: linear-gradient(135deg, #2563eb, #7c3aed); color: white; border: none; padding: 16px 40px; border-radius: 8px; font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.3s ease; display: block; width: 100%; max-width: 300px; margin: 40px auto 0; }
        .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(37, 99, 235, 0.2); }
        .contact-sidebar { background: #f8fafc; border-radius: 16px; padding: 30px; border: 1px solid #e2e8f0; margin-bottom: 30px; }
        .sidebar-title { font-size: 1.2rem; color: #0f172a; margin-bottom: 20px; font-weight: 600; }
        .contact-item { display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px; }
        .contact-icon { width: 40px; height: 40px; background: linear-gradient(135deg, #2563eb, #7c3aed); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1rem; }
        .contact-details h4 { margin: 0 0 5px 0; font-size: 0.95rem; color: #475569; font-weight: 500; }
        .contact-details p { margin: 0; color: #0f172a; font-weight: 600; font-size: 1rem; }
        .process-steps { display: flex; flex-wrap: wrap; gap: 20px; margin: 40px 0; }
        .process-step { flex: 1; min-width: 150px; text-align: center; }
        .step-circle { width: 60px; height: 60px; background: linear-gradient(135deg, #2563eb, #7c3aed); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.2rem; margin: 0 auto 15px; }
        .step-text { font-size: 0.9rem; color: #475569; }
        @@media (max-width: 768px) { .booking-title { font-size: 2.2rem; } .form-body { padding: 25px; } .event-type-grid { grid-template-columns: 1fr; } .equipment-grid { grid-template-columns: 1fr; } .process-steps { flex-direction: column; gap: 25px; } }
        .error-border { border-color: #ef4444 !important; }
        .error-message { color: #ef4444; font-size: 0.8rem; margin-top: 5px; }
    </style>
}

<!-- Header Section -->
<section class="booking-header">
    <div class="container">
        <h1 class="booking-title">Book Your Event</h1>
        <p class="booking-subtitle">
            Tell us about your event and we'll get back to you within 24 hours with a custom quote.
            We'll work with you to create the perfect audio-visual experience for your special occasion.
        </p>
        <div class="contact-badges">
            <a href="tel:+639265684372" class="contact-badge"><i class="fas fa-phone"></i><span>Call: +63 926 568 4372</span></a>
            <a href="mailto:amdaudioandlighting@gmail.com" class="contact-badge"><i class="fas fa-envelope"></i><span>Email: amdaudioandlighting@gmail.com</span></a>
            <a href="https://viber.com" target="_blank" class="contact-badge"><i class="fab fa-viber"></i><span>Viber Chat</span></a>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="booking-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="booking-container">
                    <div class="form-card">
                        <div class="form-header">
                            <h2>Event Inquiry Form</h2>
                            <p>Fill out the details below and we'll contact you to confirm your booking</p>
                        </div>

                        <form method="post" class="form-body" id="bookingForm">
                            <!-- Hidden field for Status -->
                            <input type="hidden" asp-for="Booking.Status" />
                            
                            <!-- Step 1: Personal Details -->
                            <div class="form-step">
                                <h3 class="step-title"><span class="step-number">1</span>Personal Information</h3>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Your Full Name *</label>
                                            <input type="text" class="form-control-custom" asp-for="Booking.FullName" placeholder="Enter your full name" required>
                                            <span asp-validation-for="Booking.FullName" class="error-message"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Contact Number *</label>
                                            <input type="tel" class="form-control-custom" asp-for="Booking.Phone" placeholder="e.g. 0917 123 4567" required>
                                            <span asp-validation-for="Booking.Phone" class="error-message"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Email Address *</label>
                                    <input type="email" class="form-control-custom" asp-for="Booking.Email" placeholder="your.email@example.com" required>
                                    <span asp-validation-for="Booking.Email" class="error-message"></span>
                                </div>
                            </div>

                            <!-- Step 2: Event Details -->
                            <div class="form-step">
                                <h3 class="step-title"><span class="step-number">2</span>Event Information</h3>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Event Date *</label>
                                            <input type="date" class="form-control-custom" asp-for="Booking.EventDate" required>
                                            <span asp-validation-for="Booking.EventDate" class="error-message"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Event Time</label>
                                            <input type="time" class="form-control-custom" asp-for="Booking.EventTime">
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Event Type *</label>
                                            <select class="form-select" asp-for="Booking.EventType" required>
                                                <option value="">Select event type</option>
                                                @foreach (var type in Model.EventTypes)
                                                {
                                                    <option value="@type">@type</option>
                                                }
                                            </select>
                                            <span asp-validation-for="Booking.EventType" class="error-message"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Event Duration (hours)</label>
                                            <input type="number" class="form-control-custom" asp-for="Booking.DurationHours" placeholder="e.g. 4" min="1" max="24">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 3: Venue Details -->
                            <div class="form-step">
                                <h3 class="step-title"><span class="step-number">3</span>Venue Information</h3>
                                <div class="form-group">
                                    <label class="form-label">Event Location *</label>
                                    <input type="text" class="form-control-custom" asp-for="Booking.Location" placeholder="Venue name and address" required>
                                    <span asp-validation-for="Booking.Location" class="error-message"></span>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Estimated Number of Guests</label>
                                    <input type="number" class="form-control-custom" asp-for="Booking.EstimatedGuests" placeholder="e.g. 100" min="1">
                                </div>
                            </div>

                            <!-- Step 4: Budget -->
                            <div class="form-step">
                                <h3 class="step-title"><span class="step-number">4</span>Budget Range</h3>
                                <div class="form-group">
                                    <label class="form-label">What is your estimated budget?</label>
                                    <select class="form-select" asp-for="Booking.BudgetRange">
                                        <option value="">Select budget range</option>
                                        @foreach (var budget in Model.BudgetRanges)
                                        {
                                            <option value="@budget.Value">@budget.Display</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Step 5: Equipment Requirements -->
                            <div class="form-step">
                                <h3 class="step-title"><span class="step-number">5</span>Equipment Requirements</h3>
                                <div class="form-group">
                                    <label class="form-label">Select the equipment you need:</label>
                                    @for (int i = 0; i < Model.AvailableServices.Count; i++)
                                    {
                                        var service = Model.AvailableServices[i];
                                        <div class="equipment-item" data-service="@service.Name">
                                            <div class="equipment-icon">
                                                <i class="fas @service.Icon"></i>
                                            </div>
                                            <div class="equipment-info">
                                                <h4>@service.Name</h4>
                                            </div>
                                            <input type="checkbox" class="equipment-checkbox-input"
                                                   style="display: none;"
                                                   asp-for="Booking.SelectedServices[service.Name]" />
                                            <div class="equipment-checkbox"></div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Step 6: Additional Details -->
                            <div class="form-step">
                                <h3 class="step-title"><span class="step-number">6</span>Additional Details</h3>
                                <div class="form-group">
                                    <label class="form-label">Special Requests or Requirements</label>
                                    <textarea class="form-control-custom" asp-for="Booking.AdditionalDetails" placeholder="Tell us about any specific needs, themes, or special arrangements..."></textarea>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">How did you hear about us?</label>
                                    <select class="form-select" asp-for="Booking.ReferralSource">
                                        <option value="">Select option</option>
                                        @foreach (var source in Model.ReferralSources)
                                        {
                                            <option value="@source">@source</option>
                                        }
                                    </select>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <input type="checkbox" asp-for="Booking.NeedsSetupTime" />
                                            <label asp-for="Booking.NeedsSetupTime"> I need setup time</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <input type="checkbox" asp-for="Booking.NeedsSoundCheck" />
                                            <label asp-for="Booking.NeedsSoundCheck"> I need sound check</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="submit-btn" id="submitBtn">
                                <i class="fas fa-paper-plane me-2"></i>Submit Booking Request
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="contact-sidebar">
                    <h3 class="sidebar-title">Quick Contact</h3>
                    <div class="contact-item">
                        <div class="contact-icon"><i class="fas fa-phone"></i></div>
                        <div class="contact-details"><h4>Call Us Directly</h4><p>+63 926 568 4372</p></div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                        <div class="contact-details"><h4>Email Us</h4><p>amdaudioandlighting@gmail.com</p></div>
                    </div>
                    <div class="contact-item">
                        <div class="contact-icon"><i class="fas fa-clock"></i></div>
                        <div class="contact-details"><h4>Response Time</h4><p>Within 24 hours</p></div>
                    </div>
                </div>
                <div class="process-steps">
                    <div class="process-step"><div class="step-circle">1</div><div class="step-text">Submit Request</div></div>
                    <div class="process-step"><div class="step-circle">2</div><div class="step-text">We Contact You</div></div>
                    <div class="process-step"><div class="step-circle">3</div><div class="step-text">Confirm Details</div></div>
                    <div class="process-step"><div class="step-circle">4</div><div class="step-text">Event Day!</div></div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Equipment selection - toggle checkbox
            const equipmentItems = document.querySelectorAll('.equipment-item');
            equipmentItems.forEach(item => {
                const checkbox = item.querySelector('.equipment-checkbox');
                const hiddenInput = item.querySelector('.equipment-checkbox-input');

                // Set initial state
                if (hiddenInput && hiddenInput.checked) {
                    checkbox.classList.add('checked');
                }

                item.addEventListener('click', function(e) {
                    if (e.target.closest('.equipment-checkbox') || e.target.closest('.equipment-item')) {
                        checkbox.classList.toggle('checked');
                        if (hiddenInput) {
                            hiddenInput.checked = checkbox.classList.contains('checked');
                            // Trigger change event para sa validation
                            const changeEvent = new Event('change', { bubbles: true });
                            hiddenInput.dispatchEvent(changeEvent);
                        }
                    }
                });
            });

            // Date validation - cannot select past dates
            const dateInput = document.querySelector('input[type="date"]');
            if (dateInput) {
                const today = new Date().toISOString().split('T')[0];
                dateInput.min = today;
            }

            // Form submission loading state
            const form = document.getElementById('bookingForm');
            const submitBtn = document.getElementById('submitBtn');

            if (form && submitBtn) {
                form.addEventListener('submit', function() {
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Processing...';
                    submitBtn.disabled = true;
                });
            }
        });
    </script>
}