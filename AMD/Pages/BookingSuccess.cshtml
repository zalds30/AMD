@page
@{
    ViewData["Title"] = "Booking Submitted Successfully";
    var messengerLink = TempData["MessengerLink"] as string;
    var bookingName = TempData["BookingName"] as string;
    var bookingDate = TempData["BookingDate"] as string;
    var bookingMessage = TempData["BookingMessage"] as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AMD Audio & Lighting</title>
    <link rel="icon" type="image/png" href="~/images/amd-logo.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">

    <style>
        :root {
            --black: #080a0e;
            --dark: #0d1117;
            --surface: #131820;
            --surface-2: #1a2232;
            --border: rgba(255,255,255,0.07);
            --amber: #f5a623;
            --amber-glow: #ffbe50;
            --cyan: #00d4ff;
            --green: #22c55e;
            --white: #f0f4ff;
            --muted: #6b7a96;
            --font-display: 'Bebas Neue', Impact, sans-serif;
            --font-body: 'DM Sans', system-ui, sans-serif;
            --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-body);
            background: var(--black);
            color: var(--white);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            position: relative;
            overflow-x: hidden;
        }

            /* Background glow */
            body::before {
                content: '';
                position: fixed;
                top: -20%;
                left: 50%;
                transform: translateX(-50%);
                width: 700px;
                height: 700px;
                background: radial-gradient(circle, rgba(34,197,94,0.07) 0%, transparent 65%);
                pointer-events: none;
                z-index: 0;
            }

            /* Noise grain */
            body::after {
                content: '';
                position: fixed;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
                pointer-events: none;
                z-index: 9999;
                opacity: 0.3;
            }

        /* ===== TOP BRAND BAR ===== */
        .brand-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(8,10,14,0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0.85rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            z-index: 100;
        }

            .brand-bar img {
                height: 30px;
                filter: brightness(0) invert(1);
            }

            .brand-bar span {
                font-family: var(--font-display);
                font-size: 1.2rem;
                letter-spacing: 0.08em;
                color: var(--white);
            }

            .brand-bar .brand-accent {
                color: var(--amber);
            }

        /* ===== MAIN CARD ===== */
        .success-wrap {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 620px;
            margin-top: 5rem;
            animation: slideUp 0.6s var(--ease-out) both;
        }

        @@keyframes slideUp {
            from

        {
            opacity: 0;
            transform: translateY(32px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .success-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
        }

        /* ===== HEADER ===== */
        .success-header {
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .success-header::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--green) 40%, var(--cyan) 60%, transparent);
            }

            .success-header::after {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse at 50% 0%, rgba(34,197,94,0.07) 0%, transparent 65%);
                pointer-events: none;
            }

        .check-ring {
            width: 80px;
            height: 80px;
            border: 2px solid var(--green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 2rem;
            color: var(--green);
            position: relative;
            z-index: 1;
            animation: popIn 0.5s var(--ease-out) 0.3s both;
            box-shadow: 0 0 30px rgba(34,197,94,0.15);
        }

        @@keyframes popIn {
            from

        {
            transform: scale(0.5);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }

        }

        .success-header h1 {
            font-family: var(--font-display);
            font-size: 2rem;
            letter-spacing: 0.05em;
            color: var(--white);
            margin-bottom: 0.4rem;
            position: relative;
            z-index: 1;
        }

        .success-header p {
            color: var(--muted);
            font-size: 0.9rem;
            position: relative;
            z-index: 1;
        }

        /* ===== BODY ===== */
        .success-body {
            padding: 2rem;
        }

        /* ===== ALERT BLOCK ===== */
        .info-alert {
            background: rgba(34,197,94,0.07);
            border: 1px solid rgba(34,197,94,0.25);
            border-left: 3px solid var(--green);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin-bottom: 1.5rem;
        }

            .info-alert h4 {
                color: var(--green);
                font-family: var(--font-display);
                font-size: 1.1rem;
                letter-spacing: 0.06em;
                margin-bottom: 0.35rem;
            }

            .info-alert p {
                color: var(--muted);
                font-size: 0.88rem;
                line-height: 1.7;
                margin: 0;
            }

            .info-alert strong {
                color: var(--white);
            }

        /* ===== MESSENGER CARD ===== */
        .messenger-card {
            background: var(--dark);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.75rem;
            margin-bottom: 1.5rem;
            text-align: center;
        }

            .messenger-card .messenger-icon {
                font-size: 2.5rem;
                color: #0084ff;
                margin-bottom: 0.75rem;
                display: block;
            }

            .messenger-card h3 {
                font-family: var(--font-display);
                font-size: 1.3rem;
                letter-spacing: 0.05em;
                color: var(--white);
                margin-bottom: 0.4rem;
            }

            .messenger-card > p {
                color: var(--muted);
                font-size: 0.85rem;
                margin-bottom: 1.25rem;
                line-height: 1.6;
            }

        .btn-copy {
            width: 100%;
            background: var(--surface-2);
            color: var(--muted);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.7rem 1.25rem;
            font-family: var(--font-body);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-bottom: 0.75rem;
            transition: all 0.2s ease;
            letter-spacing: 0.04em;
        }

            .btn-copy:hover {
                border-color: rgba(245,166,35,0.4);
                color: var(--amber);
            }

            .btn-copy.copied {
                background: rgba(34,197,94,0.1);
                border-color: var(--green);
                color: var(--green);
            }

        .btn-messenger {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #0084ff;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 0.75rem 1.75rem;
            font-family: var(--font-body);
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s ease, transform 0.2s ease;
        }

            .btn-messenger:hover {
                background: #006acc;
                color: white;
                transform: translateY(-1px);
            }

        .messenger-hint {
            font-size: 0.78rem;
            color: var(--muted);
            margin-top: 0.75rem;
        }

        /* ===== BOOKING DETAILS ===== */
        .details-card {
            background: var(--dark);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

            .details-card h4 {
                font-family: var(--font-display);
                font-size: 1rem;
                letter-spacing: 0.08em;
                color: var(--white);
                margin-bottom: 1rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

                .details-card h4 i {
                    color: var(--amber);
                    font-size: 0.9rem;
                }

        .booking-details {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1rem 1.25rem;
            font-family: 'DM Mono', 'Fira Code', 'Courier New', monospace;
            font-size: 0.82rem;
            line-height: 1.75;
            color: var(--muted);
            white-space: pre-wrap;
            word-break: break-word;
        }

        /* ===== NEXT STEPS ===== */
        .next-steps {
            background: var(--dark);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

            .next-steps h4 {
                font-family: var(--font-display);
                font-size: 1rem;
                letter-spacing: 0.08em;
                color: var(--white);
                margin-bottom: 1rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

                .next-steps h4 i {
                    color: var(--amber);
                    font-size: 0.85rem;
                }

        .step-list {
            list-style: none;
            padding: 0;
        }

            .step-list li {
                display: flex;
                align-items: flex-start;
                gap: 0.85rem;
                padding: 0.65rem 0;
                border-bottom: 1px solid var(--border);
                font-size: 0.88rem;
                color: var(--muted);
            }

                .step-list li:last-child {
                    border-bottom: none;
                }

                .step-list li .step-dot {
                    width: 6px;
                    height: 6px;
                    background: var(--amber);
                    border-radius: 50%;
                    flex-shrink: 0;
                    margin-top: 0.55rem;
                }

                .step-list li i {
                    color: var(--amber);
                    width: 18px;
                    font-size: 0.85rem;
                    flex-shrink: 0;
                    margin-top: 0.2rem;
                }

        /* ===== ACTION BUTTONS ===== */
        .action-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }

        .btn-action {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.85rem;
            border-radius: 6px;
            font-family: var(--font-body);
            font-weight: 600;
            font-size: 0.88rem;
            letter-spacing: 0.04em;
            text-decoration: none;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }

        .btn-action-home {
            background: var(--surface-2);
            border: 1px solid var(--border);
            color: var(--muted);
        }

            .btn-action-home:hover {
                border-color: rgba(255,255,255,0.2);
                color: var(--white);
            }

        .btn-action-call {
            background: var(--amber);
            color: var(--black);
        }

            .btn-action-call:hover {
                background: var(--amber-glow);
                color: var(--black);
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(245,166,35,0.28);
            }

        /* ===== FOOTER NOTE ===== */
        .footer-note {
            margin-top: 1.5rem;
            text-align: center;
            color: var(--muted);
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

            .footer-note i {
                color: var(--amber);
                margin-right: 0.3rem;
            }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 480px) {
            .success-body

        {
            padding: 1.25rem;
        }

        .action-buttons {
            grid-template-columns: 1fr;
        }

        .success-wrap {
            margin-top: 4.5rem;
        }

        }
    </style>
</head>
<body>

    <!-- Brand Bar -->
    <div class="brand-bar">
        <img src="~/images/amd-logo.png" alt="AMD Logo">
        <span>AMD <span class="brand-accent">Audio</span> & Lighting</span>
    </div>

    <div class="success-wrap">
        <div class="success-card">

            <!-- Header -->
            <div class="success-header">
                <div class="check-ring">
                    <i class="fas fa-check"></i>
                </div>
                <h1>Booking Submitted!</h1>
                <p>Thank you for choosing AMD Audio & Lighting</p>
            </div>

            <!-- Body -->
            <div class="success-body">

                <!-- Alert -->
                <div class="info-alert">
                    <h4>
                        <i class="fas fa-circle-check me-1"></i>
                        Thank you, @(!string.IsNullOrEmpty(bookingName) ? bookingName : "Valued Customer")!
                    </h4>
                    <p>
                        We received your booking request for
                        <strong>@(!string.IsNullOrEmpty(bookingDate) ? bookingDate : "your event")</strong>.
                        Our team will contact you within 24 hours to confirm the details.
                    </p>
                </div>

                <!-- Messenger Card -->
                <div class="messenger-card">
                    <i class="fab fa-facebook-messenger messenger-icon"></i>
                    <h3>Speed Things Up</h3>
                    <p>Send your booking details directly to our Messenger for a faster response.</p>

                    <button class="btn-copy" id="copyBtn" onclick="copyBookingDetails()">
                        <i class="fas fa-copy"></i>
                        <span id="copyText">Copy Booking Details</span>
                    </button>

                    @if (!string.IsNullOrEmpty(messengerLink))
                    {
                        <a href="@messengerLink" class="btn-messenger" target="_blank">
                            <i class="fab fa-facebook-messenger"></i> Open Messenger
                        </a>
                    }
                    else
                    {
                        <a href="https://m.me/996504260221621" class="btn-messenger" target="_blank">
                            <i class="fab fa-facebook-messenger"></i> Open Messenger
                        </a>
                    }

                    <p class="messenger-hint">
                        <i class="fas fa-info-circle"></i>
                        Click "Copy Booking Details" first, then paste it in Messenger (Ctrl+V / ⌘+V)
                    </p>
                </div>

                <!-- Booking Summary -->
                <div class="details-card">
                    <h4><i class="fas fa-receipt"></i> Booking Summary</h4>
                    <div class="booking-details" id="bookingDetails">
                        @if (!string.IsNullOrEmpty(bookingMessage))
                        {
                            @bookingMessage
                        }
                        else
                        {
                            <text>
                                Name: @bookingName
                                Status: Pending
                                Submitted: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")
                            </text>
                        }
                    </div>
                </div>

                <!-- Next Steps -->
                <div class="next-steps">
                    <h4><i class="fas fa-arrow-right-long"></i> What Happens Next</h4>
                    <ul class="step-list">
                        <li>
                            <i class="fas fa-magnifying-glass"></i>
                            <span>Our team reviews your requirements within 2–4 hours</span>
                        </li>
                        <li>
                            <i class="fas fa-file-invoice-dollar"></i>
                            <span>We prepare a customized quote based on your needs</span>
                        </li>
                        <li>
                            <i class="fas fa-phone-alt"></i>
                            <span>We contact you to discuss details and answer questions</span>
                        </li>
                        <li>
                            <i class="fas fa-handshake"></i>
                            <span>Confirm booking, schedule, and finalize arrangements</span>
                        </li>
                        <li>
                            <i class="fas fa-calendar-check"></i>
                            <span>Event day — we arrive early and make it unforgettable</span>
                        </li>
                    </ul>
                </div>

                <!-- Actions -->
                <div class="action-buttons">
                    <a href="/" class="btn-action btn-action-home">
                        <i class="fas fa-house"></i> Back to Home
                    </a>
                    <a href="tel:+639265684372" class="btn-action btn-action-call">
                        <i class="fas fa-phone-alt"></i> Call Us Now
                    </a>
                </div>

            </div>
        </div>

        <!-- Footer Note -->
        <div class="footer-note">
            <span><i class="fas fa-envelope"></i>amdaudioandlighting@gmail.com</span>
            <span><i class="fas fa-phone"></i>+63 926 568 4372</span>
        </div>
    </div>

    <script>
        function copyBookingDetails() {
            const detailsEl = document.getElementById('bookingDetails');
            let text = (detailsEl.innerText || detailsEl.textContent).trim();
            const fullMessage = `📋 AMD AUDIO & LIGHTING BOOKING REQUEST\n\n${text}\n\n---\nPlease check my booking details. Thank you! 🎉`;

            navigator.clipboard.writeText(fullMessage).then(function () {
                const btn = document.getElementById('copyBtn');
                const span = document.getElementById('copyText');
                const original = span.innerHTML;

                span.innerHTML = '<i class="fas fa-check"></i> Copied!';
                btn.classList.add('copied');

                setTimeout(function () {
                    span.innerHTML = original;
                    btn.classList.remove('copied');
                }, 2500);
            }).catch(function () {
                alert('Please manually copy your booking details from the summary above.');
            });
        }

        // Auto-copy on load after short delay
        document.addEventListener('DOMContentLoaded', function () {
            setTimeout(copyBookingDetails, 1000);
        });
    </script>
</body>
</html>
